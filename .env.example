# Public URL. Use your HTTPS URL behind Caddy in production.
KOALABYE_BASE_URL=http://localhost:8080
KOALABYE_LISTEN_ADDR=:8080
KOALABYE_DATABASE_PATH=/data/koalabye.db

# Required in production. Generate with: openssl rand -base64 48
KOALABYE_SECRET=change-me-long-random-secret

# Allowed values: selfhost, cloud
KOALABYE_MODE=selfhost
KOALABYE_REGISTRATION_ENABLED=false
KOALABYE_INVITE_ONLY=true
KOALABYE_INVITE_REGISTRATION_ENABLED=true
KOALABYE_SECURE_COOKIES=true
# Comma-separated CIDRs/IPs of reverse proxies allowed to set X-Forwarded-For /
# X-Real-IP. Leave blank when the app is exposed directly; forwarded headers are
# then ignored so login rate limits cannot be bypassed. Example: 10.0.0.0/8
KOALABYE_TRUSTED_PROXIES=
KOALABYE_INSTANCE_NAME=KoalaBye
# Optional source-code link shown in public and authenticated layouts.
KOALABYE_INSTANCE_SOURCE_URL=

# Abuse-prevention defaults. Instance Owners can adjust these in the UI.
KOALABYE_DEFAULT_MAX_ORGANIZATIONS_PER_USER=1
KOALABYE_DEFAULT_MAX_CAMPAIGNS_PER_ORG=3
KOALABYE_DEFAULT_MAX_MEMBERS_PER_ORG=5
KOALABYE_DEFAULT_MAX_ACTIVE_INVITES_PER_ORG=10
KOALABYE_DEFAULT_MAX_MONTHLY_VISITS_PER_ORG=10000
KOALABYE_DEFAULT_MAX_MONTHLY_SUBMISSIONS_PER_ORG=1000

# Optional first-owner bootstrap. Leave all blank to use /setup.
KOALABYE_BOOTSTRAP_ADMIN_USERNAME=
KOALABYE_BOOTSTRAP_ADMIN_PASSWORD=
KOALABYE_BOOTSTRAP_ADMIN_DISPLAY_NAME=
